@model IEnumerable<Order>
@{
    ViewData["Title"] = "Deliveries";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div>
        <h1>Deliveries</h1>
        <p class="page-subtitle">Active deliveries awaiting completion</p>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table class="lumina-table">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Address</th>
                    <th>Order Time</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td><strong>#@o.Id</strong></td>
                        <td>@o.User?.Name</td>
                        <td class="cell-address">@o.DeliveryAddress</td>
                        <td>@o.CreatedAt.ToString("MMM dd, HH:mm")</td>
                        <td><span class="badge badge-@o.Status.ToLower()">@o.Status</span></td>
                        <td>
                            <button type="button" class="btn btn-sm btn-primary btn-deliver" data-order-id="@o.Id">Mark as Delivered</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.btn-deliver').forEach(btn => {
    btn.addEventListener('click', async () => {
        const id = btn.dataset.orderId;
        const fd = new FormData();
        fd.append('orderId', id);
        fd.append('status', 'Delivered');
        const res = await fetch('/Admin/UpdateOrderStatus', { method: 'POST', body: fd });
        const data = await res.json();
        if (data.success) btn.closest('tr').remove();
    });
});
</script>
}
