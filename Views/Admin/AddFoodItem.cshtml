@model FoodItem
@{
    ViewData["Title"] = "Add Food Item";
    Layout = "_AdminLayout";
    var categories = ViewBag.Categories as IEnumerable<Category> ?? Enumerable.Empty<Category>();
}

<h1>Add Food Item</h1>
@if (ViewBag.Error != null) { <p class="alert alert-error">@ViewBag.Error</p> }

<form asp-action="AddFoodItem" method="post" class="admin-form">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label asp-for="Name">Name</label>
        <input asp-for="Name" required />
    </div>
    <div class="form-group">
        <label asp-for="CategoryId">Category</label>
        <select asp-for="CategoryId">
            @foreach (var cat in categories)
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label asp-for="Price">Price (Rs.)</label>
        <input asp-for="Price" type="number" step="0.01" min="1" required />
    </div>
    <div class="form-group">
        <label asp-for="Description">Description</label>
        <textarea asp-for="Description" rows="3"></textarea>
    </div>
    <div class="form-group">
        <label asp-for="ImageUrl">Image URL</label>
        <input asp-for="ImageUrl" />
    </div>
    <div class="form-group">
        <label><input asp-for="IsAvailable" type="checkbox" /> Available</label>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="FoodItems" class="btn btn-secondary">Cancel</a>
</form>
